<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gulša | Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-body: #050a13;
            --bg-card: #0d192b;
            --accent: #64ffda;
            --text-main: #a8b2d1;
            --text-white: #e6f1ff;
            --transition-smooth: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            margin: 0;
            overflow-x: hidden;
        }

        section { padding: 80px 10%; }

        .section-header { text-align: center; margin-bottom: 50px; }
        .section-header h2 { font-size: 2.5rem; color: var(--text-white); margin: 0; }
        .line { width: 60px; height: 4px; background: var(--accent); margin: 15px auto; }

        .client-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        /* SMOOTH OKIENKO */
        .client-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 40px 20px;
            border: 1px solid rgba(100, 255, 218, 0.05);
            text-align: center;
            transition: var(--transition-smooth);
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* ANIMÁCIA PRI HOVERI */
        .client-card:hover {
            transform: translateY(-10px) scale(1.03);
            border-color: var(--accent);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 20px rgba(100, 255, 218, 0.1);
        }

        .client-pfp-wrap {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            padding: 4px;
            background: linear-gradient(45deg, var(--accent), #0072ff);
            margin-bottom: 20px;
        }

        .client-pfp-wrap img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--bg-card);
        }

        .client-card h3 {
            color: var(--text-white);
            font-size: 1.5rem;
            margin: 10px 0;
        }

        .stats-row {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        /* POLOKRÚŽKY / BADGES */
        .stat-badge {
            background: rgba(100, 255, 218, 0.08);
            padding: 6px 15px;
            border-radius: 50px;
            font-size: 0.85rem;
            color: var(--accent);
            border: 1px solid rgba(100, 255, 218, 0.2);
            font-weight: bold;
        }

        .stat-badge.projects {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-white);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .client-desc {
            font-size: 0.9rem;
            opacity: 0.7;
            margin-bottom: 25px;
            min-height: 40px;
        }

        .view-works {
            font-size: 0.75rem;
            font-weight: bold;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 2px;
            border-top: 1px solid rgba(255,255,255,0.05);
            width: 100%;
            padding-top: 15px;
        }
    </style>
</head>
<body>

<section id="clients">
    <div class="section-header">
        <h2>Moji Klienti</h2>
        <div class="line"></div>
    </div>

    <div class="client-grid">
        <div class="client-card">
            <div class="client-pfp-wrap">
                <img src="IMG_1510.jpeg" alt="DrWoolf">
            </div>
            <h3>DrWoolf</h3>
            <div class="stats-row">
                <div class="stat-badge">1,4k+ Subs</div>
                <div class="stat-badge projects">8+ Proj.</div>
            </div>
            <p class="client-desc">Design & Miniatúry</p>
            <div class="view-works">Zobraziť prácu</div>
        </div>

        <div class="client-card">
            <div class="client-pfp-wrap">
                <img src="IMG_1511.jpeg" alt="Adameantius">
            </div>
            <h3>Adameantius</h3>
            <div class="stats-row">
                <div class="stat-badge">1,7k+ Subs</div>
                <div class="stat-badge projects">12+ Proj.</div>
            </div>
            <p class="client-desc">Design & Thumbnail Packy</p>
            <div class="view-works">Zobraziť prácu</div>
        </div>

        <div class="client-card" style="border-color: var(--accent);">
            <div class="client-pfp-wrap">
                <img src="IMG_0937.jpg" alt="Gulša">
            </div>
            <h3>Gulša</h3>
            <div class="stats-row">
                <div class="stat-badge">3k+ Subs</div>
                <div class="stat-badge projects">15+ Proj.</div>
            </div>
            <p class="client-desc">Video Editor & Designer</p>
            <div class="view-works">MOJE PORTFÓLIO</div>
        </div>

        <div class="client-card">
            <div class="client-pfp-wrap">
                <img src="IMG_1512.jpeg" alt="Pandak">
            </div>
            <h3>Pandak</h3>
            <div class="stats-row">
                <div class="stat-badge">6k+ Subs</div>
                <div class="stat-badge projects">20+ Proj.</div>
            </div>
            <p class="client-desc">Minecraft špecializácia</p>
            <div class="view-works">Zobraziť prácu</div>
        </div>

        <div class="client-card">
            <div class="client-pfp-wrap">
                <img src="IMG_1509.jpeg" alt="AJHTtv">
            </div>
            <h3>AJHTtv</h3>
            <div class="stats-row">
                <div class="stat-badge">6k+ Subs</div>
                <div class="stat-badge projects">10+ Proj.</div>
            </div>
            <p class="client-desc">Channel Design & Grafika</p>
            <div class="view-works">Zobraziť prácu</div>
        </div>
    </div>
</section>

</body>
</html>
